#!/bin/sh
# .githooks/pre-push
# 在每次 push 前自動更新 CHANGELOG.md，並將變更一併推送。

echo "🔄  執行 pre-push：更新 CHANGELOG.md ..."

# 收集即將推送的 commit 摘要（排除 changelog 更新本身，最多 10 筆）
PUSHED_COMMITS=$(git log origin/main..HEAD --pretty=format:"%s" --no-merges 2>/dev/null \
  | grep -v "^chore.*CHANGELOG" \
  | head -10)

# 更新 changelog
node scripts/update-changelog.js
if [ $? -ne 0 ]; then
  echo "❌  update-changelog.js 執行失敗，中止 push。"
  exit 1
fi

# 若 CHANGELOG.md 有變動，自動 commit
if [ -n "$(git status --porcelain CHANGELOG.md)" ]; then
  git add CHANGELOG.md

  if [ -n "$PUSHED_COMMITS" ]; then
    FIRST_COMMIT=$(echo "$PUSHED_COMMITS" | head -1)
    COMMIT_LIST=$(echo "$PUSHED_COMMITS" | sed 's/^/- /')
    git commit -m "chore: 自動更新 CHANGELOG.md — $FIRST_COMMIT" -m "包含：
$COMMIT_LIST"
  else
    git commit -m "chore: 自動更新 CHANGELOG.md"
  fi

  echo "📝  CHANGELOG.md 已自動 commit，將一併推送。"
fi

exit 0
