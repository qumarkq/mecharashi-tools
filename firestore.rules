rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 輔助函數 ──────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main)
          .data.role in ['ADMIN', 'OWNER'];
    }
    function isOwnerRole() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main)
          .data.role == 'OWNER';
    }

    // ── 遊戲資料（所有人可讀，管理員可寫）────────────────────────────────────
    match /pilots/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mechs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /modules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /weapons/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /backpacks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /components/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /skills/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /buffs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pilotResearch/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /globalResearch/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /enemies/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /patchVersions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 用戶資料（本人可讀寫）────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /profile/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        // 建立時只允許 role='USER'，禁止自行設為 ADMIN/OWNER
        allow create: if isOwner(userId) &&
          request.resource.data.role == 'USER';
        // 本人可更新自己 profile，但不能修改 role（防止提權）
        // OWNER 可更新任何人的 profile（包含修改 role）
        allow update: if
          (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
          isOwnerRole();
      }
      match /builds/{buildId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── collectionGroup 查詢（getAllUsers 使用 collectionGroup('profile')）──
    match /{path=**}/profile/{docId} {
      allow read: if isAdmin();
    }
  }
}
