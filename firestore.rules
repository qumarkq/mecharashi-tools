rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 輔助函數 ──────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main)
          .data.role == 'ADMIN';
    }

    // ── 遊戲資料（所有人可讀，管理員可寫）────────────────────────────────────
    match /pilots/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mechs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /modules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /weapons/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /backpacks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /components/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /skills/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /buffs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pilotResearch/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /globalResearch/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /enemies/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── 用戶資料（本人可讀寫）────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /profile/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /builds/{buildId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── collectionGroup 查詢（getAllUsers 使用 collectionGroup('profile')）──
    match /{path=**}/profile/{docId} {
      allow read: if isAdmin();
    }
  }
}
