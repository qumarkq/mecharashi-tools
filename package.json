{
  "name": "mecharashi-tools",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "git config commit.template .gitmessage && git config core.hooksPath .githooks",
    "changelog": "node scripts/update-changelog.js",
    "scrape:pilots": "node scripts/scrape-pilots.js",
    "scrape:pilots:headless": "node scripts/scrape-pilots.js --headless",
    "scrape:pilots:no-images": "node scripts/scrape-pilots.js --no-images",
    "scrape": "node scripts/scrape-pilots-v2.js",
    "scrape:headless": "node scripts/scrape-pilots-v2.js --headless",
    "scrape:debug": "node scripts/scrape-pilots-v2.js --debug",
    "scrape:test": "node scripts/scrape-pilots-v2.js --limit=1 --debug",
    "scrape:v3": "node scripts/scrape-pilots-v3.js",
    "scrape:v3:force": "node scripts/scrape-pilots-v3.js --force",
    "scrape:mechs": "node scripts/scrape-mechs.js",
    "scrape:mechs:force": "node scripts/scrape-mechs.js --force",
    "scrape:mechs:debug": "node scripts/scrape-mechs.js --debug",
    "scrape:mechs:reset": "node scripts/scrape-mechs.js --clear-mechs --force",
    "migrate": "node scripts/migrate-to-firestore.mjs",
    "migrate:dry": "node scripts/migrate-to-firestore.mjs --dry-run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "html2canvas": "^1.4.1",
    "opencc-js": "^1.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.52.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
